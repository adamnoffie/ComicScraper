/*
  Default appsettings.json file for Comic Scraper. This file will be copied to the DataPath
  directory on first run if not already present. You can edit to customize your configuration.
*/

{
  // Reusable regex patterns, referenced by name in Comics below.
  // Each regex must contain a named group "url" for the strip image URL.
  // Optional named groups: "title" (tooltip), "alt" (alt text).
  "Regexes": {
    "rgxGoComics": "\"contentUrl\":\"(?<url>https://featureassets\\.gocomics\\.com/.+?)['\"]",
    "rgxArcaMax": "<img.*?comic.*?src=['\"](?<url>.*?/newspics/.*?)['\"].*?alt=['\"](?<alt>.*?)['\"](?<title>)"
  },

  // Comics to scrape.
  // Title  - display name for the comic
  // Url    - page containing the comic strip
  // Regex  - a name from Regexes above (e.g. "rgxGoComics"), or an inline regex pattern
  "Comics": [
    // --- Syndicated comics ---
    { "Title": "Arlo and Janis", "Url": "https://www.gocomics.com/arloandjanis", "Regex": "rgxGoComics" },
    { "Title": "Foxtrot", "Url": "https://www.gocomics.com/foxtrot", "Regex": "rgxGoComics" },
    { "Title": "Mallard Fillmore", "Url": "http://www.arcamax.com/thefunnies/mallardfillmore/", "Regex": "rgxArcaMax" },
    { "Title": "Chip Bok", "Url": "http://www.arcamax.com/politics/chipbok/", "Regex": "rgxArcaMax" },

    // --- Webcomics (inline regex patterns) ---
    { "Title": "XKCD", "Url": "https://xkcd.com/", "Regex": "<img src=\"\\/\\/(?<url>imgs\\.xkcd\\.com/comics/.*?\\.(?:png|gif|jpeg|jpg))\".*?title=\"(?<alt>.*?)\".*?alt=\"(?<title>.*?)\"" },
    { "Title": "VG Cats", "Url": "http://www.vgcats.com/comics/", "Regex": "<img src=\"(?<url>images/.*?\\.(?:jpg|png|gif|jpeg))\"(?<title>)(?<alt>)" },
    { "Title": "Penny Arcade", "Url": "http://www.penny-arcade.com/comic/", "Regex": "<div class=\"comic-panel\">.*?<img src=\"(?<url>.*?)\".*?alt=\"(?<title>.*?)\"(?<alt>)" }
  ],

  // Setup Email settings to receive your comics via email. You can use a service like Gmail,
  // but you may need to generate an app password and use that here instead of your regular password.
  "EmailToAddresses": "Your E-mail <you@yahoo.com>, Another Email <another@gmail.com>",
  "EmailUseSSL": true,
  "Smtp": {
    "From": "Comic Scraper <you@gmail.com>",
    "Host": "smtp.gmail.com",
    "Port": 587,
    "UserName": "you@gmail.com",
    "Password": "##########"
  }
}
