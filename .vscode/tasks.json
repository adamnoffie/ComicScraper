{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/ComicScraper/ComicScraper.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish (win-x64)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/ComicScraper/ComicScraper.csproj",
                "-c", "Release",
                "-r", "win-x64",
                // "--self-contained",
                //"-p:PublishSingleFile=true"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish (linux-x64)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/ComicScraper/ComicScraper.csproj",
                "-c", "Release",
                "-r", "linux-x64",
                "--self-contained",
                "-p:PublishSingleFile=true"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "docker build",
            "type": "shell",
            "command": "docker build -t comicscraper ${workspaceFolder}",
            "problemMatcher": []
        },
        {
            "label": "docker push",
            "type": "shell",
            "command": "docker tag comicscraper noffie/comicscraper:${input:dockerTag} && docker push noffie/comicscraper:${input:dockerTag}",
            "dependsOn": "docker build",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "dockerTag",
            "type": "promptString",
            "description": "Docker image tag (e.g. latest, beta, v1.0)",
            "default": "latest"
        }
    ]
}